# Backend (api + worker)
# Local Postgres+PostGIS and Redis run via infra/docker-compose.yml.
# Host ports are intentionally non-standard (55432, 56379) to avoid collisions
# with any other Postgres/Redis you may already have running locally.
DATABASE_URL=postgresql+asyncpg://parcelpulse:parcelpulse@localhost:55432/parcelpulse
REDIS_URL=redis://localhost:56379/0
ANTHROPIC_API_KEY=
WEBHOOK_SIGNING_SECRET=

# Frontend (web)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
